{
    "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.26/MicrosoftTeams.schema.json",
    "manifestVersion": "1.26",
    "version": "1.0.0",
    "id": "${{TEAMS_APP_ID}}",
    "developer": {
        "name": "Yan Azevedo",
        "websiteUrl": "https://yan-azevedo.github.io/arcsmith/",
        "privacyUrl": "https://yan-azevedo.github.io/arcsmith/",
        "termsOfUseUrl": "https://yan-azevedo.github.io/arcsmith/"
    },
    "icons": {
        "color": "color.png",
        "outline": "outline.png"
    },
    "name": {
        "short": "Arc.Smith${{APP_NAME_SUFFIX}}",
        "full": "Full name for Arc.Smith"
    },
    "description": {
        "short": "Short description for Arc.Smith",
        "full": "Full description for Arc.Smith"
    },
    "accentColor": "#FFFFFF",
    "supportsChannelFeatures": "tier1",
    "composeExtensions": [],
    "permissions": [
        "identity",
        "messageTeamMembers"
    ],
    "copilotAgents": {
        "declarativeAgents": [            
            {
                "id": "declarativeAgent",
                "file": "declarativeAgent.json"
            }
        ]
    },
    "validDomains": []
}